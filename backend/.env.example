PORT=5000
NODE_ENV=development

DATABASE_URL=postgresql://taskflow_user:taskflow_pass@localhost:5432/taskflow_db
DB_SSL=false

JWT_SECRET=replace_with_min_32_char_random_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_min_32_char_random_secret
JWT_REFRESH_EXPIRES_IN=30d

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://localhost:5000

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
